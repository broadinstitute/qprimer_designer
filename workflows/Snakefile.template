# vim: ft=snakemake

############################################
# User-defined parameters
############################################

# SINGLEPLEX REQUIRED: user must fill these for singleplex, ignored if not multiplex
TARGETS = []
CROSS   = []

# shared option for multiplex and singleplex
HOST    = []

# MULTIPLEX REQUIRED: Multiplex targets, will be ignored if not multiplex
PANEL = []

# Derived sets
OFF_TARGETS = CROSS + HOST
ALL_TARGETS = list(set(TARGETS + OFF_TARGETS))

# Directories
TARGET_DIR = "target_seqs/original"

# Parameter file
PARAMS = "params.txt"

# Pipeline Design Options
MULTIPLEX = bool(int(config.get("multiplex", 0)))

############################################
# Template safety checks (fail fast)
############################################

if not TARGETS and not MULTIPLEX:
    raise ValueError(
        "TARGETS is empty. Please define TARGETS in the Snakefile."
    )

############################################
# Snakemake setup
############################################

MAX_CORES = workflow.cores or 1

import os
import sys
from pathlib import Path
import shutil

# Probe mode (singleplex only)
PROBE_MODE = bool(int(config.get("probe", 0))) and not MULTIPLEX

# Create wildcard pattern for targets
if MULTIPLEX:
    TARGETS_PATTERN = "|".join(PANEL) if PANEL else ".*"
    ALL_TARGETS_PATTERN = "|".join(set(PANEL + HOST)) if (PANEL or HOST) else ".*"
else:
    TARGETS_PATTERN = "|".join(TARGETS) if TARGETS else ".*"
    ALL_TARGETS_PATTERN = "|".join(ALL_TARGETS) if ALL_TARGETS else ".*"

# Print mode information
if PROBE_MODE:
    print("=== PROBE MODE ENABLED ===", file=sys.stderr)
else:
    print("=== PROBE MODE DISABLED ===", file=sys.stderr)

# Get probe mismatch penalty from params
def get_probe_mismatch_penalty():
    """Calculate bowtie2 mismatch penalty from PROBE_MAX_MISMATCHES."""
    if not os.path.exists(PARAMS):
        return 10  # Default
    with open(PARAMS) as f:
        for line in f:
            if line.strip().startswith('PROBE_MAX_MISMATCHES'):
                try:
                    max_mm = int(line.split('=')[1].strip().split('#')[0].strip())
                    return int(20 / max_mm)
                except:
                    return 10
    return 10  # Default if not found

PROBE_MISMATCH_PENALTY = get_probe_mismatch_penalty()

############################################
# Helper functions
############################################

def count_seqs(target):
    path = f"{TARGET_DIR}/{target}.fa"
    if not os.path.exists(path):
        raise FileNotFoundError(f"Missing FASTA file: {path}")
    with open(path) as f:
        return sum(1 for l in f if l.startswith(">"))

# grabs all other sequences in PANEL except for current target
def off_targets(on):
    return [t for t in PANEL if t != on]

def check_ids(fasta):
    """Validate primer pairs in FASTA file."""
    seen = {}

    with open(fasta) as f:
        for line in f:
            if not line.startswith(">"):
                continue

            name = line[1:].strip()
            if name.endswith("_for"):
                seen.setdefault(name[:-4], set()).add("for")
            elif name.endswith("_rev"):
                seen.setdefault(name[:-4], set()).add("rev")

    ids = sorted(pid for pid, tags in seen.items() if tags == {"for", "rev"})

    if not ids:
        raise ValueError(
            f"No valid primer pairs found in {fasta} "
            "(expected *_for and *_rev entries)."
        )

    print(f"{len(ids)} primer set(s) will be evaluated from {fasta}")

    return ids

############################################
# Evaluate mode configuration
############################################

EVALUATE = bool(int(config.get("evaluate", 0)))
FOR  = config.get("for")
REV  = config.get("rev")
PSET = config.get("pset")

if EVALUATE:
    direct_ok = FOR is not None and REV is not None
    pset_ok   = PSET is not None

    if direct_ok and pset_ok:
        raise ValueError("Use either (for, rev) OR pset, not both")

    if not direct_ok and not pset_ok:
        raise ValueError("Evaluate mode requires either (for, rev) or pset")

    if pset_ok:
        PSET_PATH = Path(PSET)
        if not PSET_PATH.exists():
            raise FileNotFoundError(f"PSET not found: {PSET_PATH}")

        PSET_NAME = PSET_PATH.stem
    else:
        PSET_NAME = "ps2eval"

############################################
# Final targets
############################################

if EVALUATE:
    rule all:
        input:
            f"evaluate/{PSET_NAME}"

elif MULTIPLEX:
    rule all:
        input:
            "final/multiplex_output.csv"

    rule select_best_multiplex:
        input:
            csvs=expand("final/{on}.csv", on=PANEL)
        output:
            "final/multiplex_output.csv"
        shell:
            "qprimer select-multiplex "
            "{input.csvs} "
            "--out {output}"

    rule build_final_output:
        wildcard_constraints:
            on=TARGETS_PATTERN
        input:
            eval_on="outputs/{on}.{on}.eval",
            eval_off=lambda wc: [f"outputs/{wc.on}.{t}.eval" for t in off_targets(wc.on)],
            fa="primer_seqs/{on}_filt.fa",
            probe_mapping_on=lambda wc: (
                f"alignments/{wc.on}.{wc.on}.probe.csv" if PROBE_MODE else []
            ),
            probe_mapping_off=lambda wc: (
                [f"alignments/{wc.on}.{t}.probe.csv" for t in off_targets(wc.on)]
                if PROBE_MODE else []
            ),
            probe_seqs=lambda wc: (
                f"primer_seqs/{wc.on}_filt_probes.fa" if PROBE_MODE else []
            )
        output:
            "final/{on}.csv"
        params:
            probe_args=lambda wc, input: (
                f"--probe-mapping-on {input.probe_mapping_on} "
                f"--probe-mapping-off {' '.join(input.probe_mapping_off)} "
                f"--probe-seqs {input.probe_seqs}"
                if PROBE_MODE else ""
            )
        shell:
            "qprimer build-output "
            "--on {input.eval_on} --off {input.eval_off} "
            "--fa {input.fa} --out {output} --name {wildcards.on} "
            "--params {PARAMS} {params.probe_args}"


else:
    rule all:
        input:
            expand("final/{virus}.csv", virus=TARGETS)

    rule build_final_output:
        wildcard_constraints:
            virus=TARGETS_PATTERN
        input:
            eval_on="outputs/{virus}.{virus}.eval",
            eval_off=lambda wc: [f"outputs/{wc.virus}.{t}.eval" for t in OFF_TARGETS],
            fa="primer_seqs/{virus}_filt.fa",
            probe_mapping_on=lambda wc: (
                f"alignments/{wc.virus}.{wc.virus}.probe.csv" if PROBE_MODE else []
            ),
            probe_mapping_off=lambda wc: (
                [f"alignments/{wc.virus}.{t}.probe.csv" for t in OFF_TARGETS]
                if PROBE_MODE else []
            ),
            probe_seqs=lambda wc: (
                f"primer_seqs/{wc.virus}_filt_probes.fa" if PROBE_MODE else []
            )
        output:
            "final/{virus}.csv"
        params:
            probe_args=lambda wc, input: (
                f"--probe-mapping-on {input.probe_mapping_on} "
                f"--probe-mapping-off {' '.join(input.probe_mapping_off)} "
                f"--probe-seqs {input.probe_seqs}"
                if PROBE_MODE else ""
            )
        shell:
            "qprimer build-output "
            "--on {input.eval_on} --off {input.eval_off} "
            "--fa {input.fa} --out {output} --name {wildcards.virus} "
            "--params {PARAMS} {params.probe_args}"


############################################
# MSA + representative selection
############################################

checkpoint choose_target_seq:
    input:
        "target_seqs/original/{virus}.fa"
    output:
        "target_seqs/choice/{virus}.txt"
    params:
        max_seqs_to_bypass_msa=5
    run:
        n = count_seqs(wildcards.virus)
        choice = (
            "original"
            if n <= params.max_seqs_to_bypass_msa
            else "representative"
        )

        os.makedirs(os.path.dirname(output[0]), exist_ok=True)
        with open(output[0], "w") as out:
            out.write(choice + "\n")


rule make_MSA:
    wildcard_constraints:
        virus=TARGETS_PATTERN
    input:
        "target_seqs/original/{virus}.fa"
    output:
        "target_seqs/msa/{virus}.aln"
    threads:
        min(2, MAX_CORES)
    shell:
        "mafft --auto --quiet --thread {threads} {input} > {output}"


rule pick_representative_seqs:
    wildcard_constraints:
        virus=TARGETS_PATTERN
    input:
        "target_seqs/msa/{virus}.aln"
    output:
        "target_seqs/representative/{virus}.fa"
    shell:
        "qprimer pick-representatives "
        "--in {input} --out {output} "
        "--params {PARAMS} --name {wildcards.virus}"

def selected_source_fa(wc):
    # Ensure the checkpoint has run and we can read its output
    ckpt = checkpoints.choose_target_seq.get(virus=wc.virus)
    choice_file = ckpt.output[0]
    choice = open(choice_file).read().strip()
    if choice == "representative":
        return f"target_seqs/representative/{wc.virus}.fa"
    else:
        return f"target_seqs/original/{wc.virus}.fa"

rule resolve_target_seq:
    wildcard_constraints:
        virus=TARGETS_PATTERN
    input:
        choice=lambda wc: checkpoints.choose_target_seq.get(virus=wc.virus).output[0], src=selected_source_fa
    output:
        "target_seqs/selected/{virus}.fa"
    run:
        os.makedirs(os.path.dirname(output[0]), exist_ok=True)
        shell("cp {input.src} {output}")

############################################
# Primer generation
############################################

rule generate_primers:
    wildcard_constraints:
        virus=TARGETS_PATTERN
    input:
        "target_seqs/selected/{virus}.fa"
    output:
        fasta="primer_seqs/{virus}_init.fa",
        features="primer_seqs/{virus}_init.feat"
    shell:
        "qprimer generate "
        "--in {input} --out {output.fasta} "
        "--params {PARAMS} --name {wildcards.virus}"


rule generate_probes:
    """Generate probe candidates from target sequences."""
    wildcard_constraints:
        virus=TARGETS_PATTERN
    input:
        "target_seqs/selected/{virus}.fa"
    output:
        fasta="primer_seqs/{virus}_probe.fa",
        features="primer_seqs/{virus}_probe.feat"
    shell:
        "qprimer generate-probe "
        "--in {input} --out {output.fasta} "
        "--params {PARAMS} --name {wildcards.virus}"


############################################
# Evaluation of user-defined primers
############################################

rule prepare_pset_fasta:
    wildcard_constraints:
        filename="[^./]+"
    output:
        fasta="evaluate/{filename}.fa"
    run:
        out = Path(output.fasta)
        out.parent.mkdir(parents=True, exist_ok=True)

        # case 1: pset provided → copy
        if config.get("pset"):
            src = Path(config["pset"])
            shutil.copyfile(src, out)

        # case 2: direct for / rev → generate
        else:
            for_seq = config["for"]
            rev_seq = config["rev"]

            with open(out, "w") as f:
                f.write(f">1_for\n{for_seq}\n>1_rev\n{rev_seq}\n")

        ids = check_ids(out)

rule prepare_features:
    wildcard_constraints:
        filename="[^./]+"
    input:
        fa="evaluate/{filename}.fa"
    output:
        feat="evaluate/{filename}.feat"
    shell:
        "qprimer prepare-features "
        "--fa {input.fa} "
        "--out {output.feat}"

rule evaluate_pset:
    wildcard_constraints:
        filename="[^./]+"
    input:
        eval_on=f"outputs/{{filename}}.{TARGETS[0]}.eval",
        eval_off=lambda wc: [f"outputs/{wc.filename}.{t}.eval" for t in OFF_TARGETS],
        fasta="evaluate/{filename}.fa"
    output:
        directory("evaluate/{filename}")
    params:
        ids=lambda wc: " ".join(check_ids(f"evaluate/{wc.filename}.fa"))
    shell:
        "qprimer export-report "
        "--on {input.eval_on} "
        "--off {input.eval_off} "
        "--out evaluate/{wildcards.filename} "
        "--names {params.ids}"


############################################
# Alignment
############################################

rule build_index:
    wildcard_constraints:
        virus=TARGETS_PATTERN
    input:
        "target_seqs/original/{virus}.fa"
    output:
        "bt2_index/{virus}.1.bt2"
    threads:
        lambda wc: min(4, MAX_CORES) if count_seqs(wc.virus) > 1000 else 1
    shell:
        "bowtie2-build --threads {threads} {input} bt2_index/{wildcards.virus}"


rule align:
    wildcard_constraints:
        virus=TARGETS_PATTERN,
        target=ALL_TARGETS_PATTERN
    input:
        fasta=lambda wc: (
            f"evaluate/{wc.virus}.fa" if EVALUATE
            else (f"primer_seqs/{wc.virus}_init.fa"
                    if wc.virus == wc.target
                    else f"primer_seqs/{wc.virus}_filt.fa")
        ),
        index="bt2_index/{target}.1.bt2"
    output:
        temp("alignments/{virus}.{target}.sam")
    threads:
        min(2, MAX_CORES)
    params:
        reference=lambda wc: f"bt2_index/{wc.target}",
        multiMap=lambda wc: min(count_seqs(wc.target) * 5, 50000),
        mapOption="--mp 2,2 --rdg 4,4 --rfg 4,4 -L 8 -N 1 --score-min L,-0.6,-0.6"
    shell:
        "bowtie2 -x {params.reference} -U {input.fasta} -f "
        "-p {threads} -k {params.multiMap} {params.mapOption} "
        "--no-hd --no-unal > {output}"


rule align_probes:
    """Align probes to targets with strict parameters."""
    wildcard_constraints:
        virus=TARGETS_PATTERN
    input:
        fasta="primer_seqs/{virus}_probe.fa",
        index="bt2_index/{virus}.1.bt2"
    output:
        temp("alignments/{virus}.{virus}.probe.sam")
    threads:
        min(2, MAX_CORES)
    params:
        reference=lambda wc: f"bt2_index/{wc.virus}",
        multiMap=lambda wc: min(count_seqs(wc.virus) * 5, 50000),
        # Strict alignment: end-to-end, no indels, mismatch penalty based on PROBE_MAX_MISMATCHES
        mapOption=f"--end-to-end --mp {PROBE_MISMATCH_PENALTY},{PROBE_MISMATCH_PENALTY} --rdg 20,20 --rfg 20,20 -N 1 --score-min L,-0.8,-0.8"
    shell:
        "bowtie2 -x {params.reference} -U {input.fasta} -f "
        "-p {threads} -k {params.multiMap} {params.mapOption} "
        "--no-hd --no-unal > {output}"


rule parse_probe_mapping:
    """Parse probe SAM file into mapping table."""
    wildcard_constraints:
        virus=TARGETS_PATTERN
    input:
        sam="alignments/{virus}.{virus}.probe.sam"
    output:
        "alignments/{virus}.{virus}.probe.csv"
    shell:
        "qprimer parse-probe-mapping "
        "--sam {input.sam} --out {output}"


rule align_filtered_probes_offtarget:
    """Align filtered probes to off-targets with less strict parameters."""
    wildcard_constraints:
        virus=TARGETS_PATTERN,
        target=ALL_TARGETS_PATTERN
    input:
        fasta="primer_seqs/{virus}_filt_probes.fa",
        index="bt2_index/{target}.1.bt2"
    output:
        temp("alignments/{virus}.{target}.probe.sam")
    threads:
        min(2, MAX_CORES)
    params:
        reference=lambda wc: f"bt2_index/{wc.target}",
        multiMap=lambda wc: min(count_seqs(wc.target) * 5, 50000),
        # Less strict alignment for off-target detection
        mapOption="--mp 2,2 --rdg 4,4 --rfg 4,4 -L 8 -N 1 --score-min L,-0.6,-0.6"
    shell:
        "bowtie2 -x {params.reference} -U {input.fasta} -f "
        "-p {threads} -k {params.multiMap} {params.mapOption} "
        "--no-hd --no-unal > {output}"


rule parse_offtarget_probe_mapping:
    """Parse off-target probe SAM file into mapping table."""
    wildcard_constraints:
        virus=TARGETS_PATTERN,
        target=ALL_TARGETS_PATTERN
    input:
        sam="alignments/{virus}.{target}.probe.sam"
    output:
        "alignments/{virus}.{target}.probe.csv"
    shell:
        "qprimer parse-probe-mapping "
        "--sam {input.sam} --out {output}"


############################################
# Mapping post-processing
############################################

rule parse_map:
    input:
        "alignments/{filename}.sam"
    output:
        temp("alignments/{filename}.parsed")
    shell:
        "sam2pairwise < {input} > {output}"


rule process_map:
    input:
        sam="alignments/{filename}.sam",
        parsed="alignments/{filename}.parsed"
    output:
        temp("alignments/{filename}.mapped.temp")
    run:
        pseqs = input.parsed + ".pseq"
        tseqs = input.parsed + ".tseq"
        matches = input.parsed + ".match"

        shell(f'awk "NR % 4 == 2" {input.parsed} > {pseqs}')
        shell(f'awk "NR % 4 == 3" {input.parsed} > {matches}')
        shell(f'awk "NR % 4 == 0" {input.parsed} > {tseqs}')
        shell(
            "cut -f1-4 {input.sam} | "
            "paste - {pseqs} | paste - {tseqs} | paste - {matches} "
            "> {output}"
        )
        shell("rm -f {pseqs} {tseqs} {matches}")


rule check_coverage:
    wildcard_constraints:
        virus=TARGETS_PATTERN,
        target=ALL_TARGETS_PATTERN
    input:
        mapped="alignments/{virus}.{target}.mapped.temp"
    output:
        "alignments/{virus}.{target}.mapped"
    params:
        min_cov=lambda wc: int(count_seqs(wc.target) * 0.95)
    run:
        if wildcards.virus != wildcards.target:
            shell("mv {input.mapped} {output}")
        else:
            shell(
                "awk '{{print $1, $3}}' {input.mapped} | sort -u | "
                "awk '{{count[$1]++}} END {{for (i in count) print i, count[i]}}' "
                "> {input.mapped}.cov"
            )
            shell(
                "awk '$2 >= {params.min_cov} {{print $1}}' "
                "{input.mapped}.cov > {input.mapped}.key"
            )
            shell(
                "awk 'NR==FNR {{keys[$1]; next}} ($1 in keys)' "
                "{input.mapped}.key {input.mapped} > {output}"
            )
            shell("rm -f {input.mapped}.cov {input.mapped}.key")


############################################
# ML evaluation and final output
############################################

rule prepare_input:
    wildcard_constraints:
        virus=TARGETS_PATTERN,
        target=ALL_TARGETS_PATTERN
    input:
        mapped="alignments/{virus}.{target}.mapped",
        prev=lambda wc: (
            [f"outputs/{wc.virus}.{wc.virus}.eval"]
            if wc.virus != wc.target and not EVALUATE else []
        ),
        ref="target_seqs/original/{target}.fa",
        features=lambda wc: (
            "evaluate/{virus}.feat" if EVALUATE
            else "primer_seqs/{virus}_init.feat"
        )
    output:
        "inputs/{virus}.{target}.input"
    params:
        ref_type=lambda wc: "on" if wc.virus == wc.target else "off",
        prev_arg=lambda wc: (
            f"--prev outputs/{wc.virus}.{wc.virus}.eval"
            if wc.virus != wc.target and not EVALUATE else ""
        )
    shell:
        "qprimer prepare-input "
        "--in {input.mapped} {params.prev_arg} --out {output} "
        "--ref {input.ref} --reftype {params.ref_type} "
        "--features {input.features} --params {PARAMS}"


rule evaluate:
    wildcard_constraints:
        virus=TARGETS_PATTERN,
        target=ALL_TARGETS_PATTERN
    input:
        inp="inputs/{virus}.{target}.input",
        ref="target_seqs/original/{target}.fa"
    output:
        "outputs/{virus}.{target}.eval"
    threads:
        min(2, MAX_CORES)
    resources:
        gpu=1
    params:
        ref_type=lambda wc: "on" if wc.virus == wc.target else "off"
    shell:
        "qprimer evaluate "
        "--in {input.inp} --out {output} "
        "--ref {input.ref} --reftype {params.ref_type} "
        "--threads {threads}"


rule filter_primer_list:
    wildcard_constraints:
        virus=TARGETS_PATTERN
    input:
        res="outputs/{virus}.{virus}.eval",
        init="primer_seqs/{virus}_init.fa",
        probe_mapping=lambda wc: (
            f"alignments/{wc.virus}.{wc.virus}.probe.csv" if PROBE_MODE else []
        ),
        probe_seqs=lambda wc: (
            f"primer_seqs/{wc.virus}_probe.fa" if PROBE_MODE else []
        )
    output:
        fasta="primer_seqs/{virus}_filt.fa",
        csv="primer_seqs/{virus}_filt.csv",
        probe_csv="primer_seqs/{virus}_filt_probes.csv",
        probe_fasta="primer_seqs/{virus}_filt_probes.fa"
    params:
        probe_args=lambda wc: (
            f"--probe-mapping alignments/{wc.virus}.{wc.virus}.probe.csv "
            f"--probe-seqs primer_seqs/{wc.virus}_probe.fa "
            f"--probe-out primer_seqs/{wc.virus}_filt_probes.csv"
            if PROBE_MODE else ""
        )
    shell:
        """
        qprimer filter --init {input.init} --scores {input.res} --out {output.fasta} --params {PARAMS} {params.probe_args}
        touch {output.probe_csv} {output.probe_fasta}
        """
